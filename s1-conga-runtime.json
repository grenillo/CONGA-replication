{
  "target": "bmv2",
  "p4info": "build/conga.p4.p4info.txtpb",
  "bmv2_json": "build/conga.json",
  "table_entries": [
    {
      "table": "MyIngress.conga_check",
      "comment": "hrecv gets CONGA-Flow treatment",
      "match": {"hdr.ipv4.dstAddr": ["10.0.5.5", 32]},
      "action_name": "MyIngress.use_conga",
      "action_params": {}
    },
    {
      "table": "MyIngress.conga_nhop",
      "comment": "flowlet_id=0 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.flowlet_id": 0},
      "action_name": "MyIngress.set_conga_nhop",
      "action_params": {
        "nhop_dmac": "08:00:00:00:00:01",
        "nhop_ipv4": "10.0.5.5",
        "port": 1
      }
    },
    {
      "table": "MyIngress.conga_nhop",
      "comment": "flowlet_id=1 -> port 2 (uplink to s4/spine1)",
      "match": {"meta.flowlet_id": 1},
      "action_name": "MyIngress.set_conga_nhop",
      "action_params": {
        "nhop_dmac": "08:00:00:00:00:02",
        "nhop_ipv4": "10.0.5.5",
        "port": 2
      }
    },
    {
      "table": "MyIngress.ecmp_group",
      "default_action": true,
      "action_name": "MyIngress.drop",
      "action_params": {}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "h1 ACKs: base=10 -> select=10 -> port 3",
      "match": {"hdr.ipv4.dstAddr": ["10.0.1.1", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 10, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "match": {"meta.ecmp_select": 10},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:01:01", "nhop_ipv4": "10.0.1.1", "port": 3}
    },
    {
      "table": "MyIngress.ecmp_group",
      "match": {"hdr.ipv4.dstAddr": ["10.0.2.2", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 11, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "match": {"meta.ecmp_select": 11},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:02:02", "nhop_ipv4": "10.0.2.2", "port": 4}
    },
    {
      "table": "MyIngress.ecmp_group",
      "match": {"hdr.ipv4.dstAddr": ["10.0.3.3", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 12, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "match": {"meta.ecmp_select": 12},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:03:03", "nhop_ipv4": "10.0.3.3", "port": 5}
    },
    {
      "table": "MyIngress.ecmp_group",
      "match": {"hdr.ipv4.dstAddr": ["10.0.4.4", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 13, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "match": {"meta.ecmp_select": 13},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:04:04", "nhop_ipv4": "10.0.4.4", "port": 6}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 1},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:01:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 2},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:01:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 3},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:01:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 4},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:02:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 5},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:03:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "match": {"standard_metadata.egress_port": 6},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:04:00"}
    }
  ]
}
