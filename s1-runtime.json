{
  "target": "bmv2",
  "p4info": "build/ecmp.p4.p4info.txtpb",
  "bmv2_json": "build/ecmp.json",
  "table_entries": [
    {
      "table": "MyIngress.ecmp_group",
      "default_action": true,
      "action_name": "MyIngress.drop",
      "action_params": {}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "hrecv: base=0, count=2 -> select in {0,1} for 2 uplinks",
      "match": {"hdr.ipv4.dstAddr": ["10.0.5.5", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 0, "ecmp_count": 2}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=0 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.ecmp_select": 0},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:01", "nhop_ipv4": "10.0.5.5", "port": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=1 -> port 2 (uplink to s4/spine1)",
      "match": {"meta.ecmp_select": 1},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:02", "nhop_ipv4": "10.0.5.5", "port": 2}
    },
    {
      "table": "MyIngress.ecmp_group",
