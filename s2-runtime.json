{
  "target": "bmv2",
  "p4info": "build/ecmp.p4.p4info.txtpb",
  "bmv2_json": "build/ecmp.json",
  "table_entries": [
    {
      "table": "MyIngress.ecmp_group",
      "default_action": true,
      "action_name": "MyIngress.drop",
      "action_params": {}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "Forward: toward hrecv on port 3",
      "match": {"hdr.ipv4.dstAddr": ["10.0.5.5", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 0, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=0 -> port 3 (hrecv)",
      "match": {"meta.ecmp_select": 0},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:05:05", "nhop_ipv4": "10.0.5.5", "port": 3}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "Return: ACKs to h1 -> uplinks, base=10 -> select=10",
      "match": {"hdr.ipv4.dstAddr": ["10.0.1.1", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 10, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=10 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.ecmp_select": 10},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:07", "nhop_ipv4": "10.0.1.1", "port": 1}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "Return: ACKs to h2 -> base=11 -> select=11",
      "match": {"hdr.ipv4.dstAddr": ["10.0.2.2", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 11, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=11 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.ecmp_select": 11},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:07", "nhop_ipv4": "10.0.2.2", "port": 1}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "Return: ACKs to h3 -> base=12 -> select=12",
      "match": {"hdr.ipv4.dstAddr": ["10.0.3.3", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 12, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=12 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.ecmp_select": 12},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:07", "nhop_ipv4": "10.0.3.3", "port": 1}
    },
    {
      "table": "MyIngress.ecmp_group",
      "comment": "Return: ACKs to h4 -> base=13 -> select=13",
      "match": {"hdr.ipv4.dstAddr": ["10.0.4.4", 32]},
      "action_name": "MyIngress.set_ecmp_select",
      "action_params": {"ecmp_base": 13, "ecmp_count": 1}
    },
    {
      "table": "MyIngress.ecmp_nhop",
      "comment": "select=13 -> port 1 (uplink to s3/spine0)",
      "match": {"meta.ecmp_select": 13},
      "action_name": "MyIngress.set_nhop",
      "action_params": {"nhop_dmac": "08:00:00:00:00:07", "nhop_ipv4": "10.0.4.4", "port": 1}
    },
    {
      "table": "MyEgress.send_frame",
      "comment": "port 1 = uplink to s3",
      "match": {"standard_metadata.egress_port": 1},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:05:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "comment": "port 2 = uplink to s4",
      "match": {"standard_metadata.egress_port": 2},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:05:00"}
    },
    {
      "table": "MyEgress.send_frame",
      "comment": "port 3 = hrecv, smac matches gateway MAC hrecv ARPed",
      "match": {"standard_metadata.egress_port": 3},
      "action_name": "MyEgress.rewrite_mac",
      "action_params": {"smac": "08:00:00:00:05:00"}
    }
  ]
}
